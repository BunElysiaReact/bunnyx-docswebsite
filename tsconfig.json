{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "jsxFactory": "React.createElement",
    "jsxFragmentFactory": "React.Fragment",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@bunny/api": [
        "./.bunny/api-client.ts"
      ],
      "@bunnyx/api": [
        "./.bunnyx/api-client.ts"
      ]
    }
  },
  "include": [
    "src*",
    "bunnyx.config.ts",
    "bunny-env.d.ts",
    ".bunny*",
    ".bunnyx/**/*"
  ]
}